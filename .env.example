# App
APP_ENV=development
APP_NAME=creator-os

# Backend
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# Frontend
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# Douyin OAuth (official only)
DOUYIN_CLIENT_ID=
DOUYIN_CLIENT_SECRET=
DOUYIN_REDIRECT_URI=http://localhost:3000/oauth/douyin/callback

# Provider mode: platform | byok
DEFAULT_PROVIDER_MODE=platform
